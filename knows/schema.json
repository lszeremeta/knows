{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://raw.githubusercontent.com/lszeremeta/knows/main/knows/schema.json",
    "title": "Knows Graph Schema",
    "description": "Schema for defining custom node and edge types in Knows property graph generator. GQL-inspired (ISO/IEC 39075).",
    "type": "object",
    "properties": {
        "$schema": {
            "type": "string",
            "format": "uri",
            "description": "Reference to the JSON Schema for validation"
        },
        "nodeLabel": {
            "type": "string",
            "minLength": 1,
            "description": "Label for all generated nodes",
            "default": "Node"
        },
        "edgeLabel": {
            "type": "string",
            "minLength": 1,
            "description": "Label for all generated edges",
            "default": "edge"
        },
        "nodeProperties": {
            "type": "object",
            "description": "Property definitions for nodes",
            "additionalProperties": {
                "$ref": "#/$defs/propertyDefinition"
            }
        },
        "edgeProperties": {
            "type": "object",
            "description": "Property definitions for edges (supports 'symmetric: true' for bidirectional consistency)",
            "additionalProperties": {
                "$ref": "#/$defs/edgePropertyDefinition"
            }
        },
        "computedNodeProperties": {
            "type": "object",
            "description": "Node properties computed from graph structure after generation",
            "additionalProperties": {
                "type": "string",
                "enum": ["degree"],
                "description": "Computation type: 'degree' = total unique connections"
            }
        }
    },
    "additionalProperties": false,
    "$defs": {
        "durationString": {
            "type": "string",
            "pattern": "^P(?!$)(?:(\\d+)Y)?(?:(\\d+)M)?(?:(\\d+)W)?(?:(\\d+)D)?(?:T(?!$)(?:(\\d+)H)?(?:(\\d+)M)?(?:(\\d+)S)?)?$",
            "description": "ISO 8601 duration with integer components, e.g. 'P1Y2M10DT2H30M'"
        },
        "isoDateString": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
            "description": "ISO date (YYYY-MM-DD)"
        },
        "typeName": {
            "type": "string",
            "enum": [
                "String", "STRING",
                "Name", "FirstName", "LastName", "FullName",
                "Email", "Phone", "Address", "City", "Country",
                "Company", "Job",
                "Text", "Sentence", "Paragraph",
                "Url", "Color", "Uuid",
                "Int", "Integer", "INTEGER", "INT64", "UINT64",
                "Float", "FLOAT64", "Double",
                "Boolean", "Bool", "BOOLEAN", "BOOL",
                "Date", "DATE", "DateTime", "DATETIME", "ZONED DATETIME",
                "Time", "Year", "Duration", "DURATION"
            ],
            "description": "Available property type names"
        },
        "propertyDefinition": {
            "allOf": [
                {
                    "oneOf": [
                        {
                            "$ref": "#/$defs/simpleType"
                        },
                        {
                            "$ref": "#/$defs/complexType"
                        },
                        {
                            "$ref": "#/$defs/enumType"
                        }
                    ]
                },
                {
                    "if": {
                        "type": "object"
                    },
                    "then": {
                        "not": {
                            "required": ["symmetric"]
                        }
                    }
                }
            ],
            "description": "Node property definition ('symmetric' is only supported on edge properties)"
        },
        "simpleType": {
            "$ref": "#/$defs/typeName",
            "description": "Simple type name"
        },
        "complexType": {
            "type": "object",
            "properties": {
                "type": {
                    "$ref": "#/$defs/typeName",
                    "description": "Property type name"
                },
                "min": {
                    "oneOf": [
                        {"type": "number"},
                        {"type": "string"}
                    ],
                    "description": "Minimum value: number (numeric types), start date as ISO YYYY-MM-DD (date types), or minimum ISO 8601 duration e.g. 'PT0S' (Duration type)"
                },
                "max": {
                    "oneOf": [
                        {"type": "number"},
                        {"type": "string"}
                    ],
                    "description": "Maximum value: number (numeric types), end date as ISO YYYY-MM-DD (date types), or maximum ISO 8601 duration e.g. 'P1Y' (Duration type)"
                },
                "precision": {
                    "type": "integer",
                    "minimum": 0,
                    "description": "Decimal places for Float and Double types"
                },
                "maxLength": {
                    "type": "integer",
                    "minimum": 5,
                    "description": "Maximum character length for Text type (minimum: 5)"
                },
                "symmetric": {
                    "type": "boolean",
                    "default": false,
                    "description": "If true, edges in both directions (A->B and B->A) will share this property value"
                }
            },
            "required": ["type"],
            "additionalProperties": false,
            "allOf": [
                {
                    "if": {
                        "properties": {
                            "type": {"enum": ["Duration", "DURATION"]}
                        },
                        "required": ["type"]
                    },
                    "then": {
                        "properties": {
                            "min": {
                                "$ref": "#/$defs/durationString"
                            },
                            "max": {
                                "$ref": "#/$defs/durationString"
                            }
                        }
                    }
                },
                {
                    "if": {
                        "properties": {
                            "type": {"enum": ["Date", "DATE"]}
                        },
                        "required": ["type"]
                    },
                    "then": {
                        "properties": {
                            "min": {
                                "$ref": "#/$defs/isoDateString"
                            },
                            "max": {
                                "$ref": "#/$defs/isoDateString"
                            }
                        }
                    }
                },
                {
                    "if": {
                        "properties": {
                            "type": {
                                "enum": [
                                    "Int", "Integer", "INTEGER", "INT64",
                                    "UINT64", "Float", "FLOAT64", "Double",
                                    "Year"
                                ]
                            }
                        },
                        "required": ["type"]
                    },
                    "then": {
                        "properties": {
                            "min": {"type": "number"},
                            "max": {"type": "number"}
                        }
                    }
                }
            ]
        },
        "enumType": {
            "type": "object",
            "properties": {
                "enum": {
                    "type": "array",
                    "items": {
                        "type": ["string", "number", "boolean"]
                    },
                    "minItems": 1,
                    "description": "List of possible values"
                },
                "symmetric": {
                    "type": "boolean",
                    "default": false,
                    "description": "If true, edges in both directions (A->B and B->A) will share this property value"
                }
            },
            "required": ["enum"],
            "additionalProperties": false
        },
        "edgePropertyDefinition": {
            "oneOf": [
                {
                    "$ref": "#/$defs/simpleType"
                },
                {
                    "$ref": "#/$defs/complexType"
                },
                {
                    "$ref": "#/$defs/enumType"
                }
            ],
            "description": "Edge property definition (same as node, but supports 'symmetric' option)"
        }
    },
    "examples": [
        {
            "nodeLabel": "Employee",
            "edgeLabel": "collaborates",
            "nodeProperties": {
                "name": "Name",
                "department": {"enum": ["HR", "Engineering", "Sales"]},
                "salary": {"type": "Int", "min": 30000, "max": 200000}
            },
            "edgeProperties": {
                "since": {"type": "Date", "symmetric": true},
                "projectCount": {"type": "Int", "min": 1, "max": 100}
            },
            "computedNodeProperties": {
                "connectionCount": "degree"
            }
        }
    ]
}
